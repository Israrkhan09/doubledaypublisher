    transition: color 0.2s, background-color 0.2s, opacity 0.3s, visibility 0.3s;
}

/* Class to hide arrows */
.scroll-arrow.hidden {
    opacity: 0;
    visibility: hidden;
    pointer-events: none; 
}

.scroll-arrow.right {
    right: 0;
    border-radius: 0 8px 8px 0; 
}

.scroll-arrow.left {
    left: 0; 
    right: auto;
    border-radius: 8px 0 0 8px; 
    border-right: none;
    box-shadow: 2px 0 5px -2px rgba(0, 0, 0, 0.1);
    width: 50px;
}

/* When the featured block is hidden, the left arrow moves to the container edge */
.books-section-container.feature-hidden .scroll-arrow.left {
    left: 0; 
    border-radius: 8px 0 0 8px;
}

.scroll-arrow:hover {
    color: var(--primary-text-color);
    background-color: #f0f0f0;
}

/* When the featured block is hidden, expand the scroll wrapper to the left */
.books-list-wrapper.expanded {
    margin-left: -300px; 
    width: calc(100% + 300px); 
    border-radius: 8px; 
}



/* --- Single Scroll Arrow --- */
.scroll-arrow {
    position: absolute;
    top: 50%;
    right: 20px; /* Fixed to the right */
    transform: translateY(-50%);
    width: 60px;
    height: 60px;
    background-color: rgba(255, 255, 255, 0.85);
    border-radius: 50%;
    border: 2px solid #ddd;
    display: flex;
    justify-content: center;
    align-items: center;
    font-size: 28px;
    color: #555;
    cursor: pointer;
    z-index: 12;
    transition: all 0.3s ease-in-out;
    box-shadow: 0 6px 12px rgba(0, 0, 0, 0.15);
    backdrop-filter: blur(6px);
}

/* Hover animation */
.scroll-arrow:hover {
    background-color: #3b82f6;
    color: #fff;
    transform: translateY(-50%) scale(1.15);
    box-shadow: 0 8px 20px rgba(59, 130, 246, 0.4);
}

/* Click bounce effect */
.scroll-arrow:active {
    transform: translateY(-50%) scale(0.95);
    box-shadow: 0 4px 10px rgba(0, 0, 0, 0.2);
}

/* Arrow icon using pseudo-element */
.scroll-arrow::after {
    content: '';
    width: 12px;
    height: 12px;
    border-top: 2px solid currentColor;
    border-right: 2px solid currentColor;
    transform: rotate(45deg);
    transition: transform 0.3s ease;
}

.scroll-arrow:hover::after {
    transform: rotate(0deg);
}
/* Left arrow icon */
.scroll-arrow.left::after {
    transform: rotate(-135deg); /* points left */
}

/* Right arrow icon */
.scroll-arrow.right::after {
    transform: rotate(45deg); /* points right */
}












































